{
  "name": "quorum",
  "version": "3.0.0",
  "description": "Quorum — workforce compliance, present and accounted for. Next.js, Prisma/PostgreSQL, NextAuth, DCM verdict engine, agent self-service portal with digital acknowledgements",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "// build": "prisma generate runs here because hosts cache node_modules — without it the client is stale or missing",
    "build": "prisma generate && next build",
    "start": "next start",
    "test": "node test/engine.test.mjs",
    "test:e2e": "node test/e2e.mjs",
    "db": "node scripts/devdb.mjs start",
    "db:stop": "node scripts/devdb.mjs stop",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "geist": "^1.7.2",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3"
  }
}
